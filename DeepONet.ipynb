    "def S_n(S):\n",
    "    return (S - S_wc) / (1 - S_wc - S_gr)\n",
    "\n",
    "def k_rw(S):\n",
    "    return ((S - S_wc) / (1 - S_wc - S_gr)) ** 4\n",
    "\n",
    "def k_rg(S):\n",
    "    return ((1 - S - S_gr) / (1 - S_wc - S_gr)) ** 2\n",
    "\n",
    "def f(S):\n",
    "    lambda_w = k_rw(S) / mu_w\n",
    "    lambda_g = k_rg(S) / mu_g\n",
    "    return lambda_w / (lambda_w + lambda_g)\n",
    "\n",
    "def rhs(t, y):\n",
    "    F = np.empty(y.shape[0] + 1, dtype=np.float32)\n",
    "    F[0] = f(S_left)\n",
    "    F[1:] = f(y)\n",
    "\n",
    "    return -(F[1:] - F[:-1]) / dx\n",
    "    "
   ]
