    "Nx = 100\n",
    "dx = L / Nx\n",
    "phi = 0.2\n",
    "u = 1e-6\n",
    "mu_w = 1e-3\n",
    "mu_g = 1e-5\n",
    "S_wc = 0.2\n",
    "S_gr = 0.1\n",
    "\n",
    "S_left = 0.9"
   ]
