    "def ODE_system_solver(f, y0, t0, final_t, step = 1e-4):\n",
    "\n",
    "    ts = np.arange(t0, final_t, step)\n",
    "    ys = np.empty((len(ts), len(y0)), dtype=np.float32)\n",
    "    ys[0] = y0\n",
    "\n",
    "    for i, t in enumerate(ts[:-1]):\n",
    "        ys[i + 1] = ys[i] + f(t, ys[i]) * step\n",
    "\n",
    "    return ts, ys"
   ]
  },
